void checkForFactoryReset() {
  if (digitalRead(SELECT_BUTTON) == HIGH) {
    unsigned long pressedAt = millis();
    while (digitalRead(SELECT_BUTTON) == HIGH && millis() - pressedAt < 3000);  // Wait up to 3s

    if (millis() - pressedAt >= 3000) {
      lcd.clear();
      lcd.setCursor(0, 0);
      lcd.print("Factory Reset...");
      delay(1500);

      setupCompleteFlag.write(false);  // Wipe config flag
      NVIC_SystemReset();              // Force hardware reboot
    }
  }
}

// === Soft Reboot Function (no flash wipe) ===
void softReboot() {
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Rebooting...");
  delay(1500);

  NVIC_SystemReset();  // Reboot the device without clearing flash
}

// === Soft Reboot Check (hold BACK for 3 seconds) ===
void checkForSoftReboot() {
  if (digitalRead(BACK_BUTTON) == HIGH) {
    unsigned long pressedAt = millis();
    while (digitalRead(BACK_BUTTON) == HIGH && millis() - pressedAt < 3000);  // Hold for 3s

    if (millis() - pressedAt >= 3000) {
      softReboot();  // Perform soft reboot
    }
  }
}



// === Setup Function ===
void setup() {
  Serial.begin(115200);

  Serial.println(loadWiFiCredentials("ssid"));
  Serial.println(loadWiFiCredentials("password"));
  Serial.println(loadWiFiCredentials("userId"));

  deviceConfigured = setupCompleteFlag.read();  // Read flag from flash
  lcd.begin(LCD_COLS, LCD_ROWS);

  pinMode(UP_BUTTON, INPUT);
  pinMode(DOWN_BUTTON, INPUT);
  pinMode(SELECT_BUTTON, INPUT);
  pinMode(BACK_BUTTON, INPUT);

  sensors.begin();

  if (deviceConfigured) {
    setupWiFi();   // ✅ Connect to WiFi on boot if already configured
    fetchTanksForUser(); // ⬅️ NEW: Load tanks from Supabase
    updateLCD();   // ✅ Show UI immediately
  } else {
    setupBLE();    // 🔁 Only show BLE screen if not configured
  }
}

void loop() {
  checkForFactoryReset();  // 🔁 Detect and allow reset
  checkForSoftReboot();     // 🔁 Soft reboot (no flash wipe)
  BLE.poll();  // Keeps BLE stack running

  // If setup already done, enter main UI logic
  if (deviceConfigured) {
    static unsigned long lastButtonPress = 0;
    const unsigned long debounceDelay = 200;

    if (millis() - lastButtonPress < debounceDelay) return;

    if (!inMeasurementScreen) {
      if (digitalRead(UP_BUTTON) == HIGH) {
        if (selectedTankIndex > 0) {
          selectedTankIndex--;
          if (selectedTankIndex < topTankIndex) topTankIndex--;
          updateLCD();
        }
        lastButtonPress = millis();
      }

      if (digitalRead(DOWN_BUTTON) == HIGH) {
        if (selectedTankIndex < 9) {
          selectedTankIndex++;
          if (selectedTankIndex > topTankIndex + 1) topTankIndex++;
          updateLCD();
        }
        lastButtonPress = millis();
      }

      if (digitalRead(SELECT_BUTTON) == HIGH) {
        inMeasurementScreen = true;
        measureSelected = false;
        updateMeasurementScreen();
        lastButtonPress = millis();
      }
    } else {
      if (digitalRead(UP_BUTTON) == HIGH || digitalRead(DOWN_BUTTON) == HIGH) {
        measureSelected = !measureSelected;
        updateMeasurementScreen();
        lastButtonPress = millis();
      }

      if (digitalRead(SELECT_BUTTON) == HIGH) {
        if (measureSelected) {
          startMeasurement();
        }
        lastButtonPress = millis();
      }

      if (digitalRead(BACK_BUTTON) == HIGH) {
        inMeasurementScreen = false;
        updateLCD();
        lastButtonPress = millis();
      }
    }

    return;  // Done with UI
  }

  // BLE pairing/setup flow
  BLEDevice central = BLE.central();
  if (central) {
    Serial.println("Phone Connected");
    lcd.clear();
    lcd.print("Paired");
    delay(1000);
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Awaiting your");

    lcd.setCursor(0, 1);
    lcd.print("signal...");


    while (central.connected()) {
      if (ssidCharacteristic.written()) {
        Serial.println("SSID written");

        String ssid = String((char*)ssidCharacteristic.value());
        String password = String((char*)passwordCharacteristic.value());
        String userId = String((char*)userIdCharacteristic.value());

        storeWiFiCredentials(ssid, password, userId);

        if (wifiCredentialsReceived) {
          Serial.println("Calling setupWifi");

          lcd.clear();
          lcd.setCursor(0, 0);

          setupWiFi();

          delay(1000);

          wifiCredentialsReceived = false;
          setupCompleteFlag.write(true);  // Save setup status
          deviceConfigured = true;  

          fetchTanksForUser(); // ⬅️ NEW: Load tanks from Supabase
          updateLCD();
          break;  // Exit BLE connection loop
        }
      }
    }
  }
}


// === WiFi Setup Function ===
void setupWiFi() {
  Serial.println("setting up wifi function");
  String ssid = loadWiFiCredentials("ssid");
  String password = loadWiFiCredentials("password");

  Serial.println(loadWiFiCredentials("ssid"));
  Serial.println(loadWiFiCredentials("password"));
  Serial.println(loadWiFiCredentials("userId"));

  if (ssid.length() == 0 || password.length() == 0) {
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Waiting for WiFi");
  } else {
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Connecting...");
    WiFi.begin(ssid.c_str(), password.c_str());
    unsigned long start = millis();

    while (WiFi.status() != WL_CONNECTED && millis() - start < 10000) {
      delay(500);
    }

    if (WiFi.status() == WL_CONNECTED) {
      lcd.clear();
      lcd.setCursor(0, 0);
      lcd.print("WiFi Connected!");
      delay(1000);
      Serial.println("✅ WiFi connected!");
      lcd.clear();
      lcd.setCursor(0, 0);
      lcd.print("Welcome");

      lcd.setCursor(0, 1);
      lcd.print("to AquaSpec!");

      delay(2000);

      lcd.setCursor(0, 0);
      lcd.print("Preparing");
      lcd.setCursor(0, 1);
      lcd.print("your tanks...");
      wifiConnected = true;
    } else {
      lcd.clear();
      lcd.setCursor(0, 0);
      lcd.print("WiFi Failed");
      Serial.println("❌ WiFi failed.");
    }
    delay(1000);
  }
}

// === Setup BLE Function ===
void setupBLE() {
  Serial.println("BLE function started");
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Scanning the");
  lcd.setCursor(0, 1);
  lcd.print("Reef...");

  if (!BLE.begin()) {
    Serial.println("Starting BLE failed!");
    while (1);
  }

  // Set the Bluetooth device name
  BLE.setDeviceName("AquaSpec Device");

  // Set the advertising interval (in milliseconds)
  BLE.setAdvertisingInterval(500);  // Set to 100ms

  // Add characteristics to the service
  wifiService.addCharacteristic(ssidCharacteristic);
  wifiService.addCharacteristic(passwordCharacteristic);
  wifiService.addCharacteristic(userIdCharacteristic);

  // Add service and start advertising
  BLE.addService(wifiService);
  BLE.advertise();

  // Log to Serial Monitor
  Serial.println("BLE Device Ready. Waiting for connection...");
}

struct WiFiCredentials {
  char ssid[33];      // +1 for null terminator
  char password[33];
  char userId[65];    // Larger size for UUIDs
};


// Clean non-printable characters
String cleanInput(String input) {
  String result = "";
  for (int i = 0; i < input.length(); i++) {
    if (isPrintable(input[i])) {
      result += input[i];
    }
  }
  return result;
}

// === Store WiFi Credentials in FlashStorage ===
void storeWiFiCredentials(String ssid, String password, String userId) {
  // Clean non-printable characters
  ssid = cleanInput(ssid);
  password = cleanInput(password);
  userId = cleanInput(userId);

  // Trim spaces
  ssid.trim();
  password.trim();
  userId.trim();

  // Remove everything after the delimiter
  int ssidDelimPos = ssid.indexOf(DELIMITER_CHAR);
  int passwordDelimPos = password.indexOf(DELIMITER_CHAR);
  int userIdDelimPos = userId.indexOf(DELIMITER_CHAR);

  if (ssidDelimPos != -1) ssid = ssid.substring(0, ssidDelimPos);
  if (passwordDelimPos != -1) password = password.substring(0, passwordDelimPos);
  if (userIdDelimPos != -1) userId = userId.substring(0, userIdDelimPos);

  // Convert to struct
  WiFiCredentials creds;
  ssid.toCharArray(creds.ssid, sizeof(creds.ssid));
  password.toCharArray(creds.password, sizeof(creds.password));
  userId.toCharArray(creds.userId, sizeof(creds.userId));

  // Write to Flash
  wifiCredsStorage.write(creds);
  wifiCredentialsReceived = true;

  // Debug output
  Serial.println("✅ Stored cleaned credentials:");
  Serial.println(creds.ssid);
  Serial.println(creds.password);
  Serial.println(creds.userId);
}


String loadWiFiCredentials(String type) {
  WiFiCredentials creds = wifiCredsStorage.read();

  if (type == "ssid") return String(creds.ssid);
  if (type == "password") return String(creds.password);
  if (type == "userId") return String(creds.userId);
  return "";
}

void fetchTanksForUser() {
  String userId = loadWiFiCredentials("userId");
  Serial.println("This what's being sent to Supabase: " + userId);
  if (!wifiConnected || userId == "") {
    Serial.println("❌ No WiFi or userId — cannot fetch tanks.");
    return;
  }

  WiFiSSLClient client;
  if (!client.connect(SUPABASE_HOST.c_str(), 443)) {
    Serial.println("⚠️ Could not connect to Supabase.");
    return;
  }

  // 🔁 Use LIKE query to match suffix
  String path = "/rest/v1/user_suffix_tanks?user_id=like.*" + userId + "&select=name,id";

  String request = "GET " + path + " HTTP/1.1\r\n";
  request += "Host: " + SUPABASE_HOST + "\r\n";
  request += "Authorization: Bearer " + SUPABASE_KEY + "\r\n";
  request += "apikey: " + SUPABASE_KEY + "\r\n";
  request += "Accept: application/json\r\n";
  request += "Connection: close\r\n\r\n";

  client.print(request);
  Serial.println("📡 Request Sent to Supabase...");

  // Skip headers
  while (client.connected()) {
    String line = client.readStringUntil('\n');
    if (line == "\r") break;
  }

  String response;
  while (client.available()) {
    response += client.readString();
  }

  client.stop();
  Serial.println("📨 Raw Response:");
  Serial.println(response);

  // 🧼 Clean up chunked response (extract JSON array only)
  int jsonStart = response.indexOf("[");
  int jsonEnd = response.lastIndexOf("]") + 1;

  if (jsonStart == -1 || jsonEnd == -1) {
    Serial.println("⚠️ Could not find valid JSON in response");
    return;
  }

  String jsonPayload = response.substring(jsonStart, jsonEnd);
  Serial.println("📦 Clean JSON Payload:");
  Serial.println(jsonPayload);

  // Parse JSON response
  DynamicJsonDocument doc(2048);
  DeserializationError err = deserializeJson(doc, jsonPayload);
  if (err) {
    Serial.print("⚠️ JSON Parse failed: ");
    Serial.println(err.c_str());
    return;
  }

  tanks.clear();  // Empty previous tank list
  for (JsonObject obj : doc.as<JsonArray>()) {
    Tank t;
    t.name = obj["name"].as<String>();
    t.id = obj["id"].as<String>();
    tanks.push_back(t);
  }

  Serial.print("✅ Loaded ");
  Serial.print(tanks.size());
  Serial.println(" tank(s).");

  selectedTankIndex = 0;
  topTankIndex = 0;
}


// === Supabase Upload Function (With Debug Logs) ===
void sendMeasurementToSupabase(String tankId, String deviceUid, float pH, int tds, float temp) {
  Serial.println("🔁 Attempting to send data to Supabase...");

  if (!wifiConnected) {
    Serial.println("❌ WiFi not connected. Upload aborted.");
    return;
  }

  // Debug log for parameter values
  Serial.println("📝 Upload Parameters:");
  Serial.print("Tank ID: "); Serial.println(tankId);
  Serial.print("Device UID: "); Serial.println(deviceUid);
  Serial.print("pH: "); Serial.println(pH, 2);
  Serial.print("TDS: "); Serial.println(tds);
  Serial.print("Temp: "); Serial.println(temp, 1);

  WiFiSSLClient client;
  Serial.print("🌐 Connecting to host: ");
  Serial.println(SUPABASE_HOST);

  if (!client.connect(SUPABASE_HOST.c_str(), 443)) {
    Serial.println("⚠️ Connection to Supabase failed.");
    showUploadStatus(false);
    return;
  }

  String payload = "{";
  payload += "\"tank_id\": \"" + tankId + "\",";
  payload += "\"device_uid\": \"" + deviceUid + "\",";
  payload += "\"ph\": " + String(pH, 2) + ",";
  payload += "\"tds\": " + String(tds) + ",";
  payload += "\"temperature\": " + String(temp, 1);
  payload += "}";

  Serial.println("📦 Payload:");
  Serial.println(payload);

  String request = "";
  request += "POST /rest/v1/sensor_readings HTTP/1.1\r\n";
  request += "Host: " + SUPABASE_HOST + "\r\n";
  request += "Authorization: Bearer " + SUPABASE_KEY + "\r\n";
  request += "apikey: " + SUPABASE_KEY + "\r\n";
  request += "Content-Type: application/json\r\n";
  request += "Content-Length: " + String(payload.length()) + "\r\n";
  request += "Connection: close\r\n\r\n";
  request += payload;

  Serial.println("📤 Full HTTP Request:");
  Serial.println(request);

  client.print(request);

  bool success = false;
  Serial.println("📡 Waiting for response...");

  while (client.connected()) {
    String line = client.readStringUntil('\n');
    Serial.print("🔹 Response Header: ");
    Serial.println(line);
    if (line.indexOf("201 Created") >= 0) success = true;
    if (line == "\r") break;  // End of headers
  }

  Serial.println("📨 Response Body:");
  while (client.available()) {
    String line = client.readStringUntil('\n');
    Serial.println(line);
  }

  client.stop();
  showUploadStatus(success);
}



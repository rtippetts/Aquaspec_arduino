// === WiFi Setup Function ===
void setupWiFi() {
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Connecting...");
  lcd.setCursor(0, 1);
  lcd.print("to WiFi");

  WiFi.begin(ssid, password);
  unsigned long start = millis();

  while (WiFi.status() != WL_CONNECTED && millis() - start < 10000) {
    delay(500);
  }

  lcd.clear();
  if (WiFi.status() == WL_CONNECTED) {
    lcd.print("WiFi connected");
    Serial.println("✅ WiFi connected!");
    wifiConnected = true;
    delay(1000);
  } else {
    lcd.print("WiFi failed");
    Serial.println("❌ WiFi failed.");
    wifiConnected = false;
    delay(2000);
  }
}

// === Supabase Upload Function ===
void sendMeasurementToSupabase(String tankId, String deviceId, float pH, int tds, float temp) {
  if (!wifiConnected) return;

  WiFiSSLClient client;
  if (!client.connect(SUPABASE_HOST.c_str(), 443)) {
    Serial.println("⚠️ Connection to Supabase failed.");
    showUploadStatus(false);
    return;
  }

  String payload = "{";
  payload += "\"tank_id\": \"" + tankId + "\",";
  payload += "\"device_id\": \"" + deviceId + "\",";
  payload += "\"ph\": " + String(pH, 2) + ",";
  payload += "\"tds\": " + String(tds) + ",";
  payload += "\"temperature\": " + String(temp, 1);
  payload += "}";

  String request = "";
  request += "POST /rest/v1/sensor_readings HTTP/1.1\r\n";
  request += "Host: " + SUPABASE_HOST + "\r\n";
  request += "Authorization: Bearer " + SUPABASE_KEY + "\r\n";
  request += "apikey: " + SUPABASE_KEY + "\r\n";
  request += "Content-Type: application/json\r\n";
  request += "Content-Length: " + String(payload.length()) + "\r\n";
  request += "Connection: close\r\n\r\n";
  request += payload;

  client.print(request);
  Serial.println("📤 Sending...");

  bool success = false;
  while (client.connected()) {
    String line = client.readStringUntil('\n');
    Serial.println(line);
    if (line.indexOf("201 Created") >= 0) success = true;
    if (line == "\r") break;
  }

  while (client.available()) {
    String line = client.readStringUntil('\n');
    Serial.println(line);
  }

  client.stop();
  showUploadStatus(success);
}

// === Show Upload Status on LCD ===

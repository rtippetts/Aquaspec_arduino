//Median Function
int getMedian(int *data, int size) {
  int temp[size];
  for (int i = 0; i < size; i++) {
    temp[i] = data[i];
  }

  for (int i = 0; i < size - 1; i++) {
    for (int j = i + 1; j < size; j++) {
      if (temp[j] < temp[i]) {
        int swap = temp[i];
        temp[i] = temp[j];
        temp[j] = swap;
      }
    }
  }

  if (size % 2 == 0) {
    return (temp[size / 2 - 1] + temp[size / 2]) / 2;
  } else {
    return temp[size / 2];
  }
}



// ph Reading Function
float readPH() {
  const int SCOUNT = 20;
  int buffer[SCOUNT];

  Serial.println("📡 PH Readings:");
  for (int i = 0; i < SCOUNT; i++) {
    buffer[i] = analogRead(PH_PIN);
    Serial.print(buffer[i]);
    Serial.print(i < SCOUNT - 1 ? ", " : "\n");
    delay(20);
  }

  int median = getMedian(buffer, SCOUNT);
  Serial.print("📊 PH Median: ");
  Serial.println(median);

  float calibratedPH = -0.0214 * median + 16.7711;
  Serial.print("✅ Calibrated pH: ");
  Serial.println(calibratedPH, 2);

  return calibratedPH;
}


// TDS Reading Function
int readTDS() {
  const int SCOUNT = 30;
  int analogBuffer[SCOUNT];

  Serial.println("📡 TDS Readings:");
  for (int i = 0; i < SCOUNT; i++) {
    analogBuffer[i] = analogRead(TDS_PIN);
    Serial.print(analogBuffer[i]);
    Serial.print(i < SCOUNT - 1 ? ", " : "\n");
    delay(20);
  }

  int median = getMedian(analogBuffer, SCOUNT);
  Serial.print("📊 TDS Median: ");
  Serial.println(median);

  float voltage = median * (5.0 / 1024.0);
  float compensatedVoltage = voltage;

  float tds = (133.42 * pow(compensatedVoltage, 3)
             - 255.86 * pow(compensatedVoltage, 2)
             + 857.39 * compensatedVoltage) * 0.5;
  int calibratedTDS = (int)(tds / 880.0 * 706.5);

  Serial.print("✅ Calibrated TDS (ppm): ");
  Serial.println(calibratedTDS);

  return calibratedTDS;
}


// Temperature reading function
float readTemp() {
  sensors.requestTemperatures();  // Ask for temp from DS18B20
  float celsius = sensors.getTempCByIndex(0);

  Serial.print("🌡️ Temperature: ");
  Serial.print(celsius, 2);
  Serial.println(" °C");

  return celsius;
}



